# This file contains example environment variables for the HTTP Server project.
# It should be copied to a `.env` file in the project root and modified with actual values.
#
# Variables defined here will be loaded by the application, typically using a library
# like `github.com/joho/godotenv` or similar, providing configuration flexibility
# without hardcoding sensitive information.

# --- Application Environment ---
# APP_ENV: The application environment.
#   - 'development': For local development, often enables more verbose logging,
#                    detailed error messages, and potentially different database settings.
#   - 'production': For live deployments, typically uses less verbose logging,
#                   generic error messages, and optimized settings.
#   - 'test': For running automated tests.
APP_ENV=development

# --- Server Configuration ---
# SERVER_PORT: The port on which the HTTP server will listen.
SERVER_PORT=8080

# SERVER_READ_TIMEOUT: The maximum duration for reading the entire request, including the body.
#                      A value of '0' means no timeout.
#                      Example: 5s, 10s, 1m
SERVER_READ_TIMEOUT=5s

# SERVER_WRITE_TIMEOUT: The maximum duration before timing out writes of the response.
#                       A value of '0' means no timeout.
#                       Example: 10s, 15s, 1m
SERVER_WRITE_TIMEOUT=10s

# SERVER_IDLE_TIMEOUT: The maximum amount of time to wait for the next request when keep-alives are enabled.
#                      A value of '0' means no timeout.
#                      Example: 60s, 120s, 5m
SERVER_IDLE_TIMEOUT=120s

# SERVER_GRACEFUL_SHUTDOWN_TIMEOUT: The maximum duration the server will wait for
#                                   active connections to finish during a graceful shutdown.
#                                   Example: 15s, 30s
SERVER_GRACEFUL_SHUTDOWN_TIMEOUT=15s

# --- Logging Configuration ---
# LOG_LEVEL: The minimum level of logs to output.
#            Possible values: debug, info, warn, error, fatal, panic
LOG_LEVEL=info

# LOG_FORMAT: The format for log output.
#             Possible values: json, text
LOG_FORMAT=text

# --- Cross-Origin Resource Sharing (CORS) Configuration ---
# CORS_ALLOWED_ORIGINS: A comma-separated list of origins that are allowed to make requests.
#                       Use "*" to allow all origins (not recommended for production).
#                       Example: http://localhost:3000,https://yourfrontend.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# CORS_ALLOWED_METHODS: A comma-separated list of HTTP methods allowed for CORS requests.
#                       Example: GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS

# CORS_ALLOWED_HEADERS: A comma-separated list of HTTP headers allowed for CORS requests.
#                       Example: Content-Type,Authorization,X-Requested-With
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# CORS_EXPOSED_HEADERS: A comma-separated list of HTTP headers that clients are allowed to access.
#                       Example: Link,X-Total-Count
CORS_EXPOSED_HEADERS=

# CORS_ALLOW_CREDENTIALS: Set to "true" to allow credentials (cookies, HTTP authentication) to be sent with requests.
#                         Must be "true" or "false".
CORS_ALLOW_CREDENTIALS=true

# CORS_MAX_AGE: The maximum age (in seconds) for which the preflight request result can be cached.
#               Example: 600 (10 minutes)
CORS_MAX_AGE=600

# --- Static File Serving Configuration ---
# STATIC_FILES_DIR: The local file system path to the directory containing static assets.
#                   This path is relative to the project root.
STATIC_FILES_DIR=./web/static

# STATIC_FILES_URL_PREFIX: The URL path prefix under which static files will be served.
#                          Example: /static/, /assets/
STATIC_FILES_URL_PREFIX=/static/

# --- Database Configuration (Example - adjust based on your actual DB) ---
# DATABASE_URL: The connection string for your database.
#               Example for PostgreSQL: postgres://user:password@host:port/dbname?sslmode=disable
#               Example for MySQL: user:password@tcp(host:port)/dbname?parseTime=true
#               If not using a database, you can remove or comment this out.
# DATABASE_URL=postgres://user:password@localhost:5432/mydatabase?sslmode=disable

# DATABASE_MAX_CONNECTIONS: The maximum number of open connections to the database.
# DATABASE_MAX_CONNECTIONS=10

# DATABASE_MAX_IDLE_CONNECTIONS: The maximum number of idle connections in the pool.
# DATABASE_MAX_IDLE_CONNECTIONS=5

# DATABASE_CONNECTION_MAX_LIFETIME: The maximum amount of time a connection may be reused.
#                                   Example: 5m, 1h
# DATABASE_CONNECTION_MAX_LIFETIME=5m

# --- API Keys / Secrets (Example) ---
# API_KEY_SECRET: A secret key used for internal API authentication or signing tokens.
#                 Generate a strong, random string for production.
# API_KEY_SECRET=your_super_secret_api_key_here

# EXTERNAL_SERVICE_API_KEY: An API key for an external service integration.
# EXTERNAL_SERVICE_API_KEY=some_external_service_key_12345